{
  "name": "petskod",
  "version": "2.0.0",
  "description": "3D Desktop Companion — Fase 2: Comportamento + TTS + Tray",
  "main": "src/app/main.js",
  "scripts": {
    "prestart": "node scripts/generate-icon.js",
    "start": "electron .",
    "dev": "node scripts/generate-icon.js && electron . --dev",
    "build": "electron-builder --win",
    "build:portable": "electron-builder --win portable"
  },
  "keywords": [
    "desktop-pet",
    "3d",
    "companion",
    "electron",
    "threejs"
  ],
  "author": "IgorDev",
  "license": "MIT",
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "three": "^0.160.0"
  },
  "build": {
    "appId": "dev.igor.petskod",
    "productName": "PETSKOD",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    }
  }
}
